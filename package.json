{
  "name": "@kacific/pglite-prisma-adapter",
  "version": "0.1.0",
  "description": "Docker-free in-process Postgres for Prisma 5 tests via PgLite + the driver-adapter pattern. Codifies the non-obvious gotchas so adoption is five lines instead of a week.",
  "keywords": [
    "prisma",
    "pglite",
    "postgres",
    "postgresql",
    "testing",
    "test",
    "vitest",
    "jest",
    "driver-adapter",
    "in-process",
    "wasm"
  ],
  "homepage": "https://github.com/Kacific/PgLite-Prisma-Adapter",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kacific/PgLite-Prisma-Adapter.git"
  },
  "bugs": {
    "url": "https://github.com/Kacific/PgLite-Prisma-Adapter/issues"
  },
  "license": "MIT",
  "author": "Kacific",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@prisma/adapter-pg": "^5.10.0",
    "@prisma/client": "^5.10.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@prisma/adapter-pg": "5.22.0",
    "@prisma/client": "5.22.0",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.0",
    "prisma": "5.22.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.5"
  }
}
